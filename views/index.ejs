<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lapor Sampah Liar</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #d4fc79, #96e6a1);
            min-height: 100vh;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

        .title {
            font-weight: 700;
            color: #198754;
        }

        .btn-custom {
            background: linear-gradient(135deg, #28a745, #20c997);
            border: none;
            transition: 0.3s;
        }

        .btn-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .list-item {
            border-radius: 15px;
            margin-bottom: 10px;
            transition: 0.2s;
        }

        .list-item:hover {
            transform: scale(1.01);
            background: rgba(255,255,255,0.8);
        }

        .badge-status {
            background: #ffc107;
            color: #333;
            font-weight: 500;
        }

    </style>
</head>

<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">

                <!-- Header -->
                <div class="text-center mb-4">
                    <h2 class="title">♻️ Lapor Sampah Liar</h2>
                    <p class="text-muted">Bantu jaga kebersihan lingkungan dengan melaporkan tumpukan sampah liar di sekitarmu.</p>
                </div>

                <!-- Form -->
                <div class="glass-card p-4 mb-5">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Kirim Laporan Baru</h5>

                    <form action="/lapor" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Lokasi Tumpukan Sampah</label>
                            <input type="text" class="form-control rounded-pill" name="lokasi" placeholder="Contoh: Jl. Braga No. 10" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Deskripsi Kondisi</label>
                            <textarea class="form-control rounded-4" name="deskripsi" rows="3" placeholder="Ceritakan detail..." required></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Upload Foto Bukti</label>
                            <input type="file" class="form-control rounded-pill" name="foto" accept="image/*" required>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-custom btn-lg rounded-pill fw-bold">
                                🚀 Lapor Sekarang!
                            </button>
                        </div>
                    </form>
                </div>

                <h4 class="fw-bold mb-3">📋 Daftar Laporan Masuk</h4>

                <div class="glass-card p-3">
                    <% if(laporan.length > 0) { %>
                        <% laporan.forEach(function(item) { %>
                            <div class="list-item p-3 border-bottom">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold text-success mb-0"><%= item.lokasi %></h6>
                                    <span class="badge badge-status rounded-pill">Menunggu</span>
                                </div>

                                <p class="text-muted mb-2"><%= item.deskripsi %></p>

                                <a href="<%= item.foto_url %>" target="_blank"
                                   class="btn btn-sm btn-outline-primary rounded-pill">
                                    🖼️ Lihat Foto
                                </a>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center text-muted p-5">
                            Belum ada laporan yang masuk
                        </div>
                    <% } %>
                </div>

            </div>
        </div>
    </div>
</body>
</html>